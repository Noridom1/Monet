+def _summarize_response_body(text, secret='', limit=1200):
+    if text is None:
+        return '<empty>'
+    body = str(text).strip()
+    if secret:
+        body = body.replace(secret, '[REDACTED]')
+    if len(body) > limit:
+        body = body[:limit] + '...<truncated>'
+    return body
